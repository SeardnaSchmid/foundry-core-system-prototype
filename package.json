{
  "name": "tno",
  "version": "0.22.4",
  "description": "SCSS compiler for the Trans-Neptunian Objects Foundry VTT system",
  "scripts": {
    "build": "sass src/scss/tno.scss css/tno.css --style=expanded --no-source-map",
    "watch": "sass src/scss/tno.scss css/tno.css --style=expanded --source-map --watch",
    "release": "release-it",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "ZR",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@release-it/bumper": "^7.0.6",
    "@release-it/conventional-changelog": "^11.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "release-it": "^20.2.1",
    "sass": "^1.53.0",
    "vitest": "^4.1.10"
  }
}
