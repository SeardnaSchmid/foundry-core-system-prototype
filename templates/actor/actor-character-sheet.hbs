<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
      <div class="resources flexrow">

        {{!-- Initiative wird gewürfelt mit Initiativegrundwert+1d10. --}}
        <a class="resource-group initiative-group rollable" data-roll="1d10 + @derived.initiative" data-label="{{localize 'JOSTER.Derived.Initiative'}}" title="{{localize 'JOSTER.DerivedHint.Initiative'}}">
          <span class="initiative-value">{{system.derived.initiative}}<small>+1d10</small></span>
          <span class="initiative-label">{{localize "JOSTER.DerivedShort.Initiative"}}</span>
        </a>

        {{!-- Sechster Sinn wird mit dem regulären 3d20-Wurf gegen den Wert selbst gewürfelt, ohne Mods/Advantage. --}}
        <a class="resource-group sixth-sense-group rollable" data-roll-type="sixthSense" data-label="{{localize 'JOSTER.Derived.SixthSense'}}" title="{{localize 'JOSTER.Derived.SixthSense'}}: {{localize 'JOSTER.DerivedHint.SixthSense'}}">
          <span class="sixth-sense-value">{{system.derived.sixthSense}}</span>
          <label class="sixth-sense-label">{{localize "JOSTER.DerivedShort.SixthSense"}}</label>
        </a>

        {{!-- Bewegungsreichweiten sind reine Anzeigewerte, kein Wurf. --}}
        <div class="resource-group movement-group">
          <div class="movement-tile" title="{{localize 'JOSTER.Derived.MovementCrawl'}}: {{localize 'JOSTER.DerivedHint.MovementCrawl'}}">
            <span class="movement-value">{{system.derived.movementCrawl}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.MovementCrawl"}}</label>
          </div>
          <div class="movement-tile" title="{{localize 'JOSTER.Derived.MovementWalk'}}: {{localize 'JOSTER.DerivedHint.MovementWalk'}}">
            <span class="movement-value">{{system.derived.movementWalk}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.MovementWalk"}}</label>
          </div>
          <div class="movement-tile" title="{{localize 'JOSTER.Derived.MovementSprint'}}: {{localize 'JOSTER.DerivedHint.MovementSprint'}}">
            <span class="movement-value">{{system.derived.movementSprint}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.MovementSprint"}}</label>
          </div>
          <div class="movement-tile carry-slots-tile" title="{{localize 'JOSTER.Derived.CarrySlots'}}: {{localize 'JOSTER.DerivedHint.CarrySlots'}}">
            <span class="movement-value">{{system.derived.carrySlotsUsed}}/{{system.derived.carrySlots}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.CarrySlots"}}</label>
          </div>
        </div>

        {{!-- Problemlösen: Vorrat zeigt den aktuell verbleibenden Punktestand
        an (Maximalwert minus Verbrauch) und ist direkt editierbar, geclampt
        auf 0..Maximalwert. Die Tiles daneben sind reine Anzeigewerte im
        selben Stil wie die Bewegungsreichweiten (movement-tile), bis auf
        "Analyse": "Fehler Analysieren" ist als Wurf umgesetzt (ein
        regulärer 3d20-Wurf gegen den Wert; bei Erfolg wird ein Vorrat-Punkt
        zurückgewonnen) und steht direkt neben dem Vorrat, als einziges
        klickbares Tile hier. "Idee haben" ist ein Pre-Edge und lebt als
        Toggle im Würfel-Dialog selbst (JosterRollDialog); "Fehler finden"
        ist ein Post-Edge und lebt auf der Wurf-Karte einer fehlgeschlagenen
        Probe im Chat (siehe chat.mjs) — beide nur zur Übersicht hier
        gezeigt, ohne eigenen Klick-Effekt. "Neuer Versuch" wird hier
        bewusst nicht gezeigt: ohne attributabhängigen Schwellenwert (fixer
        Punktkosten-Edge) bringt ein Anzeigewert dafür nichts. --}}
        <div class="resource-group problem-solving-group">
          <div class="reserve-pool" title="{{localize 'JOSTER.Derived.SolveReserve'}}: {{localize 'JOSTER.DerivedHint.SolveReserve'}} — {{localize 'JOSTER.DerivedHint.SolveReserveUsage'}}">
            <span class="reserve-value">
              <input type="number" class="reserve-value-input" value="{{system.derived.solveReserve}}" min="0" max="{{system.derived.solveReserveMax}}"/>/{{system.derived.solveReserveMax}}
            </span>
            <label class="reserve-label">{{localize "JOSTER.DerivedShort.SolveReserve"}}</label>
          </div>
          <a class="solve-tile solve-analyze-flaw rollable {{#if analyzeFlawDisabled}}solve-tile-disabled{{/if}}" data-roll-type="analyzeFlaw" data-label="{{localize 'JOSTER.Derived.SolveAnalyzeFlaw'}}" title="{{#if analyzeFlawDisabled}}{{localize 'JOSTER.Notify.ReserveFull'}}{{else}}{{localize 'JOSTER.Derived.SolveAnalyzeFlaw'}}: {{localize 'JOSTER.DerivedHint.SolveAnalyzeFlaw'}}{{/if}}">
            <span class="solve-tile-value">{{system.derived.solveAnalyzeFlaw}}</span>
            <label class="solve-tile-label">{{localize "JOSTER.DerivedShort.SolveAnalyzeFlaw"}}</label>
          </a>
          <div class="solve-tile" title="{{localize 'JOSTER.Derived.SolveIdea'}}: {{localize 'JOSTER.DerivedHint.SolveIdea'}}">
            <span class="solve-tile-value">{{system.derived.solveIdea}}</span>
            <label class="solve-tile-label">{{localize "JOSTER.DerivedShort.SolveIdea"}}</label>
          </div>
          <div class="solve-tile" title="{{localize 'JOSTER.Derived.SolveFindFlaw'}}: {{localize 'JOSTER.DerivedHint.SolveFindFlaw'}}">
            <span class="solve-tile-value">{{system.derived.solveFindFlaw}}</span>
            <label class="solve-tile-label">{{localize "JOSTER.DerivedShort.SolveFindFlaw"}}</label>
          </div>
        </div>

        {{!-- Gesamt-XP, die bislang in Attribute und Fertigkeiten investiert
        wurden (Summe der kumulierten Stufenkosten beider Bereiche), plus die
        Aufschlüsselung nach Fertigkeiten und Attributen. --}}
        <div class="resource-group xp-total-group" title="{{localize 'JOSTER.XpTotalHint'}}">
          <div class="xp-tile">
            <span class="xp-tile-value">{{totalXpSpent}}</span>
            <label class="xp-tile-label">{{localize "JOSTER.XpTotalAll"}}</label>
          </div>
          <div class="xp-tile">
            <span class="xp-tile-value">{{attributeGrid.totalXp}}</span>
            <label class="xp-tile-label">{{localize "JOSTER.XpTotalAttributes"}}</label>
          </div>
          <div class="xp-tile">
            <span class="xp-tile-value">{{skillXpTotal}}</span>
            <label class="xp-tile-label">{{localize "JOSTER.XpTotalSkills"}}</label>
          </div>
        </div>

      </div>
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    {{!-- Default tab is specified in actor-sheet.mjs --}}
    <a class="item" data-tab="basics">Basics</a>
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="items">Items</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Basics Tab --}}
    <div class="tab basics" data-group="primary" data-tab="basics">
      <section class="flexcol">

        {{!-- Primary attributes, laid out as a heatmap: one column per category
        (körperlich/sozial/geistig) and one row per attribute pairing,
        mirroring the "Attribute" table in the rulebook. Cell and sum-badge
        backgrounds are color-graded relative to the character's own values,
        ported from the "Attribut-Heatmap" prototype. --}}
        <div class="attributes-header flexrow">
          <h3 class="attributes-title">{{localize "JOSTER.AttributesTitle"}} <span class="xp-badge">{{attributeGrid.totalXp}}xp</span></h3>
        </div>
        <table class="attribute-table heatmap">
          <thead>
            <tr>
              <th class="attribute-corner"></th>
              {{#each attributeGrid.colHeaders as |col|}}
              <th>
                <span class="heatmap-col-label">{{col.label}}</span>
              </th>
              {{/each}}
            </tr>
          </thead>
          <tbody>
            {{#each attributeGrid.rows as |row|}}
            <tr>
              <th class="heatmap-row-header">
                <span class="heatmap-row-label">{{row.label}}</span>
              </th>
              {{#each row.cells as |cell|}}
              <td class="heatmap-cell{{#if cell.isPeak}} heatmap-peak{{/if}}{{#if cell.isCritical}} heatmap-critical{{/if}}" style="background:{{cell.cellBg}}; color:{{cell.textColor}}; border-color:{{cell.critBorder}};" title="{{cell.hint}}">
                <div class="heatmap-cell-top">
                  {{#if cell.hasDelta}}
                  <a class="heatmap-delta" data-key="{{cell.key}}" title="{{#if cell.isCritical}}{{localize 'JOSTER.AttributeCritical'}} — {{/if}}{{localize 'JOSTER.ResetTemp'}}" style="background:{{cell.deltaBg}}; color:{{cell.deltaText}};">{{#if cell.isCritical}}⚠ {{/if}}{{cell.deltaLabel}}</a>
                  {{else if cell.isCritical}}
                  <span class="heatmap-warn-badge" title="{{localize 'JOSTER.AttributeCritical'}}">⚠</span>
                  {{/if}}
                  <span class="heatmap-cell-name">{{cell.label}}</span>
                  <a class="heatmap-xp-badge{{#if cell.xpReady}} ready{{/if}}" data-key="{{cell.key}}" title="{{cell.xp}}/{{cell.xpCost}} xp — {{localize 'JOSTER.AttributeAdvanceHint'}}">{{#if cell.xpAtMax}}{{localize "JOSTER.XpMaxBadge"}}{{else}}{{cell.xp}}/{{cell.xpCost}}{{/if}}</a>
                </div>
                <div class="heatmap-cell-values flexrow flex-center">
                  <a class="heatmap-stepper" data-key="{{cell.key}}" data-action="decrement" title="{{localize 'JOSTER.AttributeDecrease'}}" style="background:{{cell.stepperBg}}; border-color:{{cell.stepperBorder}}; color:{{cell.stepperColor}};">−</a>
                  <span class="heatmap-value-pair">
                    <span class="heatmap-temp active" title="{{cell.tempHint}}">{{cell.tempValue}}</span>{{#if cell.hasDelta}}<span class="heatmap-slash">/</span><span class="heatmap-base inactive" title="{{cell.baseHint}}">{{cell.baseValue}}</span>{{/if}}
                  </span>
                  <a class="heatmap-stepper" data-key="{{cell.key}}" data-action="increment" title="{{localize 'JOSTER.AttributeIncrease'}}" style="background:{{cell.stepperBg}}; border-color:{{cell.stepperBorder}}; color:{{cell.stepperColor}};">+</a>
                </div>
                <div class="heatmap-xp-bar{{#if cell.xpReady}} ready{{/if}}" style="background:{{cell.xpBarTrack}};">
                  <span class="heatmap-xp-bar-fill" style="width:{{cell.xpPercent}}%; background:{{cell.xpBarFill}};"></span>
                </div>
              </td>
              {{/each}}
            </tr>
            {{/each}}
          </tbody>
        </table>

        {{!-- Skills, grouped by category. Each skill rolls with its linked
        attribute; the rank is added as the roll dialog's starting bonus. --}}
        <div class="skills-header flexrow">
          <h3 class="skills-title">{{localize "JOSTER.SkillsTitle"}} <span class="xp-badge">{{skillXpTotal}}xp</span></h3>
          <input type="text" class="skill-search-input" value="{{skillSearch}}" placeholder="{{localize 'JOSTER.SkillSearchPlaceholder'}}" title="{{localize 'JOSTER.SkillSearchHint'}}" />
          <div class="skill-filter-group">
            <a class="skill-filter-btn {{#ifEquals skillFilter 'trained'}}active{{/ifEquals}}" data-filter="trained" title="{{localize 'JOSTER.SkillFilterTrainedHint'}}">{{localize "JOSTER.SkillFilterTrained"}}</a>
            <a class="skill-filter-btn {{#ifEquals skillFilter 'starter'}}active{{/ifEquals}}" data-filter="starter" title="{{localize 'JOSTER.SkillFilterStarterHint'}}">{{localize "JOSTER.SkillFilterStarter"}}</a>
            <a class="skill-filter-btn {{#ifEquals skillFilter 'all'}}active{{/ifEquals}}" data-filter="all" title="{{localize 'JOSTER.SkillFilterAllHint'}}">{{localize "JOSTER.SkillFilterAll"}}</a>
          </div>
        </div>
        <div class="skill-groups">
          {{#each skillGroups as |group|}}
          <div class="skill-group">
            <h4 class="skill-group-title">
              <span class="skill-group-name">{{group.label}}</span>
              <span class="xp-badge">{{group.totalRank}} / {{group.totalXp}}xp</span>
            </h4>
            {{#if group.skills.length}}
            <ul class="skill-list">
              {{#each group.skills as |skill|}}
              <li class="skill-row" data-rank="{{skill.rank}}" data-starter="{{skill.starter}}">
                <span class="skill-info rollable" data-roll-type="skill" data-skill="{{skill.key}}" data-ability="{{skill.attribute}}" data-label="{{skill.label}}" title="{{localize 'JOSTER.RollSkill'}}: {{skill.label}}">
                  <span class="skill-name">{{skill.label}}</span>
                  <span class="skill-level">{{skill.rank}}</span>
                  <span class="skill-xp">{{skill.xp}}/{{skill.xpCost}}</span>
                </span>
                <a class="skill-advance-button{{#if skill.xpReady}} ready{{/if}}" data-skill="{{skill.key}}" title="{{localize 'JOSTER.SkillAdvance'}}">
                  <i class="fas fa-arrow-up"></i>
                </a>
              </li>
              {{/each}}
            </ul>
            {{else}}
            <p class="skill-group-empty">{{localize "JOSTER.SkillCategoryEmptyHint"}}</p>
            {{/if}}
          </div>
          {{/each}}
        </div>

      </section>
    </div>

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="description">
      {{!-- Plain textarea instead of the ProseMirror editor helper: the
      editor requires an explicit click into an edit mode before typing,
      which is unnecessary friction for a simple freetext notes field. --}}
      <textarea name="system.biography" class="biography-textarea">{{system.biography}}</textarea>
    </div>

    {{!-- Owned Items Tab --}}
    <div class="tab items" data-group="primary" data-tab="items">
       {{> "systems/joster/templates/actor/parts/actor-items.hbs"}}
    </div>

  </section>
</form>
