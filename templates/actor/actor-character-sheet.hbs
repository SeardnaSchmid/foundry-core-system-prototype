<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
      <div class="resources flexrow">

        {{!-- Initiative wird gewürfelt mit Initiativegrundwert+1d10. --}}
        <a class="resource-group initiative-group rollable" data-roll="1d10 + @derived.initiative" data-label="{{localize 'JOSTER.Derived.Initiative'}}" title="{{localize 'JOSTER.DerivedHint.Initiative'}}">
          <span class="initiative-value">{{system.derived.initiative}}<small>+1d10</small></span>
          <span class="initiative-label">{{localize "JOSTER.DerivedShort.Initiative"}}</span>
        </a>

        {{!-- Sechster Sinn wird mit dem regulären 3d20-Wurf gegen den Wert selbst gewürfelt, ohne Mods/Advantage. --}}
        <a class="resource-group sixth-sense-group rollable" data-roll-type="sixthSense" data-label="{{localize 'JOSTER.Derived.SixthSense'}}" title="{{localize 'JOSTER.Derived.SixthSense'}}: {{localize 'JOSTER.DerivedHint.SixthSense'}}">
          <span class="sixth-sense-value">{{system.derived.sixthSense}}</span>
          <label class="sixth-sense-label">{{localize "JOSTER.DerivedShort.SixthSense"}}</label>
        </a>

        {{!-- Bewegungsreichweiten sind reine Anzeigewerte, kein Wurf. --}}
        <div class="resource-group movement-group">
          <div class="movement-tile" title="{{localize 'JOSTER.Derived.MovementCrawl'}}: {{localize 'JOSTER.DerivedHint.MovementCrawl'}}">
            <span class="movement-value">{{system.derived.movementCrawl}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.MovementCrawl"}}</label>
          </div>
          <div class="movement-tile" title="{{localize 'JOSTER.Derived.MovementWalk'}}: {{localize 'JOSTER.DerivedHint.MovementWalk'}}">
            <span class="movement-value">{{system.derived.movementWalk}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.MovementWalk"}}</label>
          </div>
          <div class="movement-tile" title="{{localize 'JOSTER.Derived.MovementSprint'}}: {{localize 'JOSTER.DerivedHint.MovementSprint'}}">
            <span class="movement-value">{{system.derived.movementSprint}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.MovementSprint"}}</label>
          </div>
          <div class="movement-tile carry-slots-tile" title="{{localize 'JOSTER.Derived.CarrySlots'}}: {{localize 'JOSTER.DerivedHint.CarrySlots'}}">
            <span class="movement-value">{{system.derived.carrySlotsUsed}}/{{system.derived.carrySlots}}</span>
            <label class="movement-label">{{localize "JOSTER.DerivedShort.CarrySlots"}}</label>
          </div>
        </div>

        {{!-- Problemlösen: Vorrat zeigt den aktuell verbleibenden Punktestand
        an (Maximalwert minus Verbrauch). "Idee haben" und "Fehler finden"
        werfen selbst keine Würfel, sie geben nur Bonus/Wiederholversuche
        auf einen anderen Wurf; ein Klick verbraucht dennoch einen
        Vorrat-Punkt. "Fehler Analysieren" ist laut Regeln zusätzlich ein
        eigener Wurf. Jede Anwendung kostet einen Vorrat-Punkt. --}}
        <div class="resource-group problem-solving-group">
          <div class="reserve-pool" title="{{localize 'JOSTER.Derived.SolveReserve'}}: {{localize 'JOSTER.DerivedHint.SolveReserve'}}">
            <span class="reserve-value">{{system.derived.solveReserve}}/{{system.derived.solveReserveMax}}</span>
            <label class="reserve-label">{{localize "JOSTER.DerivedShort.SolveReserve"}}</label>
          </div>
          <div class="problem-solving-actions">
            <a class="ps-action ps-spend" data-spend="idea" title="{{localize 'JOSTER.Derived.SolveIdea'}}: {{localize 'JOSTER.DerivedHint.SolveIdea'}}">
              <span class="ps-action-label">{{localize "JOSTER.DerivedShort.SolveIdea"}}</span>
              <span class="ps-action-value">{{system.derived.solveIdea}}</span>
            </a>
            <a class="ps-action ps-spend" data-spend="findFlaw" title="{{localize 'JOSTER.Derived.SolveFindFlaw'}}: {{localize 'JOSTER.DerivedHint.SolveFindFlaw'}}">
              <span class="ps-action-label">{{localize "JOSTER.DerivedShort.SolveFindFlaw"}}</span>
              <span class="ps-action-value">{{system.derived.solveFindFlaw}}</span>
            </a>
            <a class="ps-action ps-spend" data-spend="analyzeFlaw" data-roll="1d10 + @derived.solveAnalyzeFlaw" data-label="{{localize 'JOSTER.Derived.SolveAnalyzeFlaw'}}" title="{{localize 'JOSTER.Derived.SolveAnalyzeFlaw'}}: {{localize 'JOSTER.DerivedHint.SolveAnalyzeFlaw'}}">
              <span class="ps-action-label">{{localize "JOSTER.DerivedShort.SolveAnalyzeFlaw"}}</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    {{!-- Default tab is specified in actor-sheet.mjs --}}
    <a class="item" data-tab="basics">Basics</a>
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="items">Items</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Basics Tab --}}
    <div class="tab basics" data-group="primary" data-tab="basics">
      <section class="flexcol">

        {{!-- Primary attributes, laid out as a heatmap: one column per category
        (körperlich/sozial/geistig) and one row per attribute pairing,
        mirroring the "Attribute" table in the rulebook. Cell and sum-badge
        backgrounds are color-graded relative to the character's own values,
        ported from the "Attribut-Heatmap" prototype. --}}
        <table class="attribute-table heatmap">
          <thead>
            <tr>
              <th class="attribute-corner">
                <span class="heatmap-info-badge" title="{{localize 'JOSTER.AttributeModeHint'}}">i</span>
              </th>
              {{#each attributeGrid.colHeaders as |col|}}
              <th>
                <span class="heatmap-col-label">{{col.label}}</span>
              </th>
              {{/each}}
            </tr>
          </thead>
          <tbody>
            {{#each attributeGrid.rows as |row|}}
            <tr>
              <th class="heatmap-row-header">
                <span class="heatmap-row-label">{{row.label}}</span>
              </th>
              {{#each row.cells as |cell|}}
              <td class="heatmap-cell{{#if cell.isPeak}} heatmap-peak{{/if}}{{#if cell.isCritical}} heatmap-critical{{/if}}" style="background:{{cell.cellBg}}; color:{{cell.textColor}}; border-color:{{cell.critBorder}};" title="{{cell.hint}}">
                <div class="heatmap-cell-top">
                  {{#if cell.isCritical}}
                  <span class="heatmap-warn" title="{{localize 'JOSTER.AttributeCritical'}}">⚠</span>
                  {{/if}}
                  <span class="heatmap-cell-name" data-key="{{cell.key}}">{{cell.label}}</span>
                  {{#if cell.hasDelta}}
                  <a class="heatmap-delta" data-key="{{cell.key}}" title="{{localize 'JOSTER.ResetTemp'}}" style="background:{{cell.deltaBg}}; color:{{cell.deltaText}};">{{cell.deltaLabel}}</a>
                  {{/if}}
                </div>
                <div class="heatmap-cell-values flexrow flex-center">
                  <a class="heatmap-stepper" data-key="{{cell.key}}" data-action="decrement" title="{{localize 'JOSTER.AttributeDecrease'}}" style="background:{{cell.stepperBg}}; border-color:{{cell.stepperBorder}}; color:{{cell.stepperColor}};">−</a>
                  <span class="heatmap-value-pair">
                    <span class="heatmap-temp active" title="{{cell.tempHint}}">{{cell.tempValue}}</span><span class="heatmap-slash">/</span><span class="heatmap-base inactive" title="{{cell.baseHint}}">{{cell.baseValue}}</span>
                  </span>
                  <a class="heatmap-stepper" data-key="{{cell.key}}" data-action="increment" title="{{localize 'JOSTER.AttributeIncrease'}}" style="background:{{cell.stepperBg}}; border-color:{{cell.stepperBorder}}; color:{{cell.stepperColor}};">+</a>
                </div>
              </td>
              {{/each}}
            </tr>
            {{/each}}
          </tbody>
        </table>

        {{!-- Skills, grouped by category. Each skill rolls with its linked
        attribute; the rank is added as the roll dialog's starting bonus. --}}
        <div class="skills-header flexrow">
          <h3 class="skills-title">{{localize "JOSTER.SkillsTitle"}}</h3>
          <a class="free-roll-button rollable" data-roll-type="free" title="{{localize 'JOSTER.Roll.FreeHint'}}">
            <i class="fas fa-dice-d20"></i> {{localize "JOSTER.Roll.FreeTitle"}}
          </a>
        </div>
        <div class="skill-groups">
          {{#each skillGroups as |group|}}
          <div class="skill-group">
            <h4 class="skill-group-title">{{group.label}}</h4>
            {{#if group.skills.length}}
            <ul class="skill-list">
              {{#each group.skills as |skill|}}
              <li class="skill-row">
                <span class="skill-info rollable" data-roll-type="skill" data-skill="{{skill.key}}" data-ability="{{skill.attribute}}" data-label="{{skill.label}}" title="{{localize 'JOSTER.RollSkill'}}: {{skill.label}} ({{skill.attributeLabel}})">
                  <span class="skill-name">{{skill.label}}</span>
                  <span class="skill-attr">{{skill.attributeAbbr}} {{skill.attributeValue}}</span>
                  <span class="skill-threshold">{{skill.defaultThreshold}}</span>
                </span>
                <input type="number" class="skill-rank-input" name="system.skills.{{skill.key}}.value" value="{{skill.rank}}" min="0" max="10"/>
              </li>
              {{/each}}
            </ul>
            {{else}}
            <p class="skill-group-empty">{{localize "JOSTER.SkillCategoryEmptyHint"}}</p>
            {{/if}}
          </div>
          {{/each}}
        </div>

      </section>
    </div>

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="description">
      {{!-- Editors must receive enriched text data from getData to properly handle rolls --}}
      {{editor enrichedBiography target="system.biography" engine="prosemirror" button=true editable=editable}}
    </div>

    {{!-- Owned Items Tab --}}
    <div class="tab items" data-group="primary" data-tab="items">
       {{> "systems/joster/templates/actor/parts/actor-items.hbs"}}
    </div>

  </section>
</form>
