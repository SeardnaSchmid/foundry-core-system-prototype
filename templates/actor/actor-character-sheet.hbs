<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  <div class="sheet-columns flexrow">

    {{!-- Sidebar: portrait plus all derived meta stats, docked to the left
    and visible across every tab, mirroring the reference dnd5e sheet's
    layout. --}}
    <aside class="sidebar flexcol">
      {{!-- Initiative and Sixth Sense are the sidebar's two "roll" stats, so
      they sit as pill/lozenge chips overlaid on the portrait's bottom edge
      (mirroring the reference dnd5e sheet's Initiative/Speed/Proficiency
      lozenges) — this reclaims the vertical space a separate row above the
      meta cards used to take. The lozenges are opaque, so they stay legible
      on any uploaded portrait. --}}
      <div class="portrait-wrap">
        <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="360" width="300"/>

        <div class="lozenges flexrow portrait-overlay">
          {{!-- Initiative wird gewürfelt mit Initiativegrundwert+1d10. --}}
          <a class="lozenge rollable" data-roll="1d10 + @derived.initiative" data-label="{{localize 'TNO.Derived.Initiative'}}" title="{{localize 'TNO.DerivedHint.Initiative'}}">
            <span class="lozenge-value">{{system.derived.initiative}}<small>+1d10</small></span>
            <span class="lozenge-label">{{localize "TNO.DerivedShort.Initiative"}}</span>
          </a>

          {{!-- Sechster Sinn wird mit dem regulären 3d20-Wurf gegen den Wert selbst gewürfelt, ohne Mods/Advantage. --}}
          <a class="lozenge rollable" data-roll-type="sixthSense" data-label="{{localize 'TNO.Derived.SixthSense'}}" title="{{localize 'TNO.Derived.SixthSense'}}: {{localize 'TNO.DerivedHint.SixthSense'}}">
            <span class="lozenge-value">{{system.derived.sixthSense}}</span>
            <span class="lozenge-label">{{localize "TNO.DerivedShort.SixthSense"}}</span>
          </a>
        </div>
      </div>

      <div class="sidebar-stats flexcol">

        {{!-- Bewegungsreichweiten sind reine Anzeigewerte, kein Wurf. --}}
        <div class="resource-group card movement-group">
          <div class="movement-tile" title="{{localize 'TNO.Derived.MovementCrawl'}}: {{localize 'TNO.DerivedHint.MovementCrawl'}}">
            <span class="movement-value">{{system.derived.movementCrawl}}</span>
            <label class="movement-label">{{localize "TNO.DerivedShort.MovementCrawl"}}</label>
          </div>
          <div class="movement-tile" title="{{localize 'TNO.Derived.MovementWalk'}}: {{localize 'TNO.DerivedHint.MovementWalk'}}">
            <span class="movement-value">{{system.derived.movementWalk}}</span>
            <label class="movement-label">{{localize "TNO.DerivedShort.MovementWalk"}}</label>
          </div>
          <div class="movement-tile" title="{{localize 'TNO.Derived.MovementSprint'}}: {{localize 'TNO.DerivedHint.MovementSprint'}}">
            <span class="movement-value">{{system.derived.movementSprint}}</span>
            <label class="movement-label">{{localize "TNO.DerivedShort.MovementSprint"}}</label>
          </div>
          <div class="movement-tile carry-slots-tile" title="{{localize 'TNO.Derived.CarrySlots'}}: {{localize 'TNO.DerivedHint.CarrySlots'}}">
            <span class="movement-value">{{system.derived.carrySlotsUsed}}/{{system.derived.carrySlots}}</span>
            <label class="movement-label">{{localize "TNO.DerivedShort.CarrySlots"}}</label>
          </div>
        </div>

        {{!-- Problemlösen: Vorrat zeigt den aktuell verbleibenden Punktestand
        an (Maximalwert minus Verbrauch) und ist direkt editierbar, geclampt
        auf 0..Maximalwert. Die Tiles daneben sind reine Anzeigewerte im
        selben Stil wie die Bewegungsreichweiten (movement-tile), bis auf
        "Analyse": "Fehler Analysieren" ist als Wurf umgesetzt (ein
        regulärer 3d20-Wurf gegen den Wert; bei Erfolg wird ein Vorrat-Punkt
        zurückgewonnen) und steht direkt neben dem Vorrat, als einziges
        klickbares Tile hier. "Idee haben" ist ein Pre-Edge und lebt als
        Toggle im Würfel-Dialog selbst (TnoRollDialog); "Fehler finden"
        ist ein Post-Edge und lebt auf der Wurf-Karte einer fehlgeschlagenen
        Probe im Chat (siehe chat.mjs) — beide nur zur Übersicht hier
        gezeigt, ohne eigenen Klick-Effekt. "Neuer Versuch" wird hier
        bewusst nicht gezeigt: ohne attributabhängigen Schwellenwert (fixer
        Punktkosten-Edge) bringt ein Anzeigewert dafür nichts. --}}
        <div class="resource-group card problem-solving-group">
          {{!-- Tooltips read "Short Label — mechanic", not the old "Long
          Title: mechanic" (which doubled up on punctuation once the hint
          itself used a colon). The short label already matches the tile's
          on-screen caption, so hovering confirms what you're looking at
          before explaining how it works. --}}
          <div class="reserve-pool{{#if analyzeFlawDisabled}} reserve-full{{/if}}" title="{{localize 'TNO.DerivedShort.SolveReserve'}} — {{localize 'TNO.DerivedHint.SolveReserve'}}">
            <span class="reserve-value">
              <input type="number" class="reserve-value-input" value="{{system.derived.solveReserve}}" min="0" max="{{system.derived.solveReserveMax}}"/>/{{system.derived.solveReserveMax}}
            </span>
            <label class="reserve-label">{{localize "TNO.DerivedShort.SolveReserve"}}</label>
          </div>
          <a class="solve-tile solve-analyze-flaw rollable {{#if analyzeFlawDisabled}}solve-tile-disabled{{/if}}" data-roll-type="analyzeFlaw" data-label="{{localize 'TNO.Derived.SolveAnalyzeFlaw'}}" title="{{#if analyzeFlawDisabled}}{{localize 'TNO.DerivedShort.SolveAnalyzeFlaw'}} — {{localize 'TNO.Notify.ReserveFull'}}{{else}}{{localize 'TNO.DerivedShort.SolveAnalyzeFlaw'}} — {{localize 'TNO.DerivedHint.SolveAnalyzeFlaw'}}{{/if}}">
            {{!-- d20 marks this tile as the one you can actually click/roll,
            distinguishing it at rest from the display-only Idea Bonus / Find
            Flaw tiles beside it (hidden while the tile is inert/full). --}}
            <i class="fa-solid fa-dice-d20 solve-roll-mark"></i>
            <span class="solve-tile-value"><span class="solve-tile-affix">&le;</span><span class="solve-tile-number">{{system.derived.solveAnalyzeFlaw}}</span></span>
            <label class="solve-tile-label">{{localize "TNO.DerivedShort.SolveAnalyzeFlaw"}}</label>
          </a>
          <div class="solve-tile" title="{{localize 'TNO.DerivedShort.SolveIdea'}} — {{localize 'TNO.DerivedHint.SolveIdea'}}">
            <span class="solve-tile-value"><span class="solve-tile-affix">+</span><span class="solve-tile-number">{{system.derived.solveIdea}}</span></span>
            <label class="solve-tile-label">{{localize "TNO.DerivedShort.SolveIdea"}}</label>
          </div>
          <div class="solve-tile" title="{{localize 'TNO.DerivedShort.SolveFindFlaw'}} — {{localize 'TNO.DerivedHint.SolveFindFlaw'}}">
            <span class="solve-tile-value"><span class="solve-tile-number">{{system.derived.solveFindFlaw}}</span><span class="solve-tile-affix solve-tile-suffix">{{localize "TNO.UnitRep"}}</span></span>
            <label class="solve-tile-label">{{localize "TNO.DerivedShort.SolveFindFlaw"}}</label>
          </div>
        </div>

      </div>
    </aside>

    <div class="sheet-main flexcol">

  {{!-- Sheet Header: name band spanning only the main columns (2-4/4),
  not the sidebar. The total XP spent across attributes + skills rides at the
  band's right edge as a badge — this is the value's home (it used to hang as
  an orphaned footer line under the sidebar) and it fills what was otherwise a
  near-empty row holding a single-word name. --}}
  <header class="sheet-header">
    <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
    <span class="xp-badge xp-badge-total" title="{{localize 'TNO.XpTotalAllHint'}}">{{totalXpSpent}} XP</span>
  </header>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Basics Tab --}}
    <div class="tab basics" data-group="primary" data-tab="basics">
      <section class="flexcol">

        {{!-- Primary attributes, laid out as a heatmap: one column per category
        (körperlich/sozial/geistig) and one row per attribute pairing,
        mirroring the "Attribute" table in the rulebook. Cell and sum-badge
        backgrounds are color-graded relative to the character's own values,
        ported from the "Attribut-Heatmap" prototype. --}}
        <div class="attributes-header flexrow">
          <h3 class="attributes-title">{{localize "TNO.AttributesTitle"}} <span class="xp-badge" title="{{localize 'TNO.XpTotalAttributesHint'}}">{{attributeGrid.totalValue}} {{localize "TNO.UnitPoints"}} · {{attributeGrid.totalXp}} {{localize "TNO.UnitXp"}}</span></h3>
          {{#if isGM}}
          <a class="heatmap-lab-btn" title="{{localize 'TNO.Settings.HeatmapPreset.BtnHint'}}"><i class="fa-solid fa-palette"></i></a>
          {{/if}}
        </div>
        <div class="attributes-card">
        <table class="attribute-table heatmap">
          <thead>
            <tr>
              <th class="attribute-corner"></th>
              {{#each attributeGrid.colHeaders as |col|}}
              <th>
                <span class="heatmap-col-label">{{col.label}}</span>
              </th>
              {{/each}}
            </tr>
          </thead>
          <tbody>
            {{#each attributeGrid.rows as |row|}}
            <tr>
              <th class="heatmap-row-header">
                <span class="heatmap-row-label">{{row.label}}</span>
              </th>
              {{#each row.cells as |cell|}}
              <td class="heatmap-cell{{#if cell.isPeak}} heatmap-peak{{/if}}{{#if cell.isCritical}} heatmap-critical{{/if}}" style="background:{{cell.cellBg}}; color:{{cell.textColor}}; border-color:{{cell.critBorder}};" title="{{cell.hint}}">
                <div class="heatmap-cell-top">
                  {{#if cell.hasDelta}}
                  <a class="heatmap-delta" data-key="{{cell.key}}" title="{{#if cell.isCritical}}{{localize 'TNO.AttributeCritical'}} — {{/if}}{{localize 'TNO.ResetTemp'}}" style="background:{{cell.deltaBg}}; color:{{cell.deltaText}};">{{#if cell.isCritical}}⚠ {{/if}}{{cell.deltaLabel}}</a>
                  {{else if cell.isCritical}}
                  <span class="heatmap-warn-badge" title="{{localize 'TNO.AttributeCritical'}}">⚠</span>
                  {{/if}}
                  <span class="heatmap-cell-name">{{cell.label}}</span>
                </div>
                <div class="heatmap-cell-values flexrow flex-center">
                  <a class="heatmap-stepper" data-key="{{cell.key}}" data-action="decrement" title="{{localize 'TNO.AttributeDecrease'}}" style="background:{{cell.stepperBg}}; border-color:{{cell.stepperBorder}}; color:{{cell.stepperColor}};">−</a>
                  {{!-- Modified attributes read as "base → effective" (e.g.
                  6→4) so the direction of the change is explicit and never
                  gets misread as an x/y progress ratio like the sidebar's
                  reserve/carry tiles. The effective (temp) value stays the
                  emphasised one on the right. --}}
                  <span class="heatmap-value-pair">
                    {{#if cell.hasDelta}}<span class="heatmap-base inactive" title="{{cell.baseHint}}">{{cell.baseValue}}</span><span class="heatmap-arrow">→</span>{{/if}}<span class="heatmap-temp active" title="{{cell.tempHint}}">{{cell.tempValue}}</span>
                  </span>
                  <a class="heatmap-stepper" data-key="{{cell.key}}" data-action="increment" title="{{localize 'TNO.AttributeIncrease'}}" style="background:{{cell.stepperBg}}; border-color:{{cell.stepperBorder}}; color:{{cell.stepperColor}};">+</a>
                </div>
                <a class="heatmap-xp-bar{{#if cell.xpReady}} ready{{/if}}" data-key="{{cell.key}}" style="background:{{cell.xpBarTrack}};" title="{{#if cell.xpAtMax}}{{localize 'TNO.XpMaxBadge'}}{{else}}{{cell.xp}}/{{cell.xpCost}} xp{{/if}} — {{localize 'TNO.AttributeAdvanceHint'}}">
                  <span class="heatmap-xp-bar-fill" style="width:{{cell.xpPercent}}%; background:{{cell.xpBarFill}};"></span>
                </a>
              </td>
              {{/each}}
            </tr>
            {{/each}}
          </tbody>
        </table>
        </div>

        {{!-- Skills, grouped by category. Each skill rolls with its linked
        attribute; the rank is added as the roll dialog's starting bonus. --}}
        <div class="skills-header flexrow">
          <h3 class="skills-title">{{localize "TNO.SkillsTitle"}} <span class="xp-badge" title="{{localize 'TNO.XpTotalSkillsHint'}}">{{skillRankTotal}} {{localize "TNO.UnitPoints"}} · {{skillXpTotal}} {{localize "TNO.UnitXp"}}</span></h3>
          <input type="text" class="skill-search-input" value="{{skillSearch}}" placeholder="{{localize 'TNO.SkillSearchPlaceholder'}}" title="{{localize 'TNO.SkillSearchHint'}}" />
          <div class="skill-filter-group">
            <a class="skill-filter-btn {{#ifEquals skillFilter 'trained'}}active{{/ifEquals}}" data-filter="trained" title="{{localize 'TNO.SkillFilterTrainedHint'}}">{{localize "TNO.SkillFilterTrained"}}</a>
            <a class="skill-filter-btn {{#ifEquals skillFilter 'starter'}}active{{/ifEquals}}" data-filter="starter" title="{{localize 'TNO.SkillFilterStarterHint'}}">{{localize "TNO.SkillFilterStarter"}}</a>
            <a class="skill-filter-btn {{#ifEquals skillFilter 'all'}}active{{/ifEquals}}" data-filter="all" title="{{localize 'TNO.SkillFilterAllHint'}}">{{localize "TNO.SkillFilterAll"}}</a>
          </div>
        </div>
        {{!-- Scroll wrapper owns the vertical overflow (fixed height from the
        flex column); the inner .skill-groups is a balanced CSS multi-column
        flow whose height is content-driven, so long skill lists (the ALL
        filter) fill all three columns evenly and scroll here rather than
        scrolling the whole sheet. --}}
        <div class="skill-groups-scroll">
        <div class="skill-groups">
          {{#each skillGroups as |group|}}
          <div class="card skill-group">
            <h4 class="skill-group-title">
              <span class="skill-group-name">{{group.label}}</span>
              <span class="xp-badge">{{group.totalRank}}pt | {{group.totalXp}}xp</span>
              {{#if @root.editable}}
              <a class="skill-create-button" data-category="{{group.key}}" title="{{localize 'TNO.CustomSkill.Add'}}">
                <i class="fas fa-plus"></i>
              </a>
              {{/if}}
            </h4>
            {{#if group.skills.length}}
            <ul class="skill-list">
              {{#each group.skills as |skill|}}
              <li class="skill-row" data-rank="{{skill.rank}}" data-xp="{{skill.xp}}" data-starter="{{skill.starter}}" data-custom="{{skill.custom}}">
                <span class="skill-info rollable" data-roll-type="skill" data-skill="{{skill.key}}" data-ability="{{skill.attribute}}" data-label="{{skill.label}}" title="{{#if skill.custom}}{{localize 'TNO.CustomSkill.ShiftClickHint'}}{{else}}{{localize 'TNO.RollSkill'}}: {{skill.label}}{{/if}}">
                  <span class="skill-name">
                    {{!-- Own title so the full name still shows on hover even
                    when the outer .skill-info title is the shift-click hint
                    (custom skills) rather than the roll hint. --}}
                    <span class="skill-name-text" title="{{skill.label}}">{{skill.label}}</span>
                    {{#if skill.subgroupBadge}}
                    <span class="skill-subgroup-badge" title="{{skill.subgroupLabel}}">{{skill.subgroupBadge}}</span>
                    {{/if}}
                    {{#if skill.custom}}
                    <span class="skill-custom-badge" title="{{localize 'TNO.CustomSkill.BadgeHint'}}">{{localize "TNO.CustomSkill.Badge"}}</span>
                    {{/if}}
                  </span>
                  <span class="skill-level"{{#if skill.levelBg}} style="background:{{skill.levelBg}}; color:{{skill.levelColor}};"{{/if}}>{{skill.rank}}</span>
                  {{!-- XP-toward-next-rank bar, mirroring the attribute heatmap's
                  xp bar: fill/color communicate progress at a glance, exact
                  figures live in the tooltip, and clicking it opens the same
                  advance dialog as the arrow button beside it. --}}
                  <a class="skill-xp-bar{{#if skill.xpReady}} ready{{/if}}" data-skill="{{skill.key}}" title="{{#if skill.xpAtMax}}{{localize 'TNO.XpMaxBadge'}}{{else}}{{skill.xp}}/{{skill.xpCost}} xp{{/if}} — {{localize 'TNO.SkillAdvance'}}">
                    <span class="skill-xp-bar-fill" style="width:{{skill.xpPercent}}%;"></span>
                  </a>
                </span>
                <a class="skill-advance-button{{#if skill.xpReady}} ready{{/if}}" data-skill="{{skill.key}}" title="{{localize 'TNO.SkillAdvance'}}">
                  <i class="fas fa-arrow-up"></i>
                </a>
              </li>
              {{/each}}
            </ul>
            {{else}}
            <p class="skill-group-empty">{{localize "TNO.SkillCategoryEmptyHint"}}</p>
            {{/if}}
          </div>
          {{/each}}
        </div>
        </div>

      </section>
    </div>

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="description">
      {{!-- Plain textarea instead of the ProseMirror editor helper: the
      editor requires an explicit click into an edit mode before typing,
      which is unnecessary friction for a simple freetext notes field. --}}
      <textarea name="system.biography" class="biography-textarea" placeholder="{{localize 'TNO.BiographyPlaceholder'}}">{{system.biography}}</textarea>
    </div>

    {{!-- Owned Items Tab --}}
    <div class="tab items" data-group="primary" data-tab="items">
       {{> "systems/tno/templates/actor/parts/actor-items.hbs"}}
    </div>

  </section>

    </div>

  </div>

  {{!-- Sheet Tab Navigation, docked as a vertical icon rail along the right
  edge, mirroring the reference dnd5e sheet's tab layout. Each item also
  carries a text label, hidden by default and revealed on hover/focus (see
  _forms.scss), so the rail's purpose as tab navigation is discoverable
  without waiting on the native tooltip's delay. --}}
  <nav class="sheet-tabs tabs tabs-right" data-group="primary">
    {{!-- Default tab is specified in actor-sheet.mjs --}}
    <a class="item" data-tab="basics"><i class="fa-solid fa-chart-simple"></i><span class="tab-label">{{localize 'TNO.TabBasics'}}</span></a>
    <a class="item" data-tab="description"><i class="fa-solid fa-feather"></i><span class="tab-label">{{localize 'TNO.TabDescription'}}</span></a>
    <a class="item" data-tab="items"><i class="fa-solid fa-suitcase"></i><span class="tab-label">{{localize 'TNO.TabItems'}}</span></a>
  </nav>
</form>
