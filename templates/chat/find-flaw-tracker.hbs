<div class="tno-find-flaw-tracker">
  <div class="tno-find-flaw-header">
    <span class="tno-find-flaw-label"><i class="fa-solid fa-magnifying-glass"></i> {{localize "TNO.Derived.SolveFindFlaw"}}</span>
    <div class="tno-find-flaw-pips">
      {{#each pips as |pip|}}
      <span class="tno-find-flaw-pip{{#if pip.filled}} filled{{/if}}{{#if pip.success}} success{{/if}}"></span>
      {{/each}}
    </div>
  </div>

  {{#each attempts as |attempt|}}
  <div class="tno-find-flaw-attempt {{attempt.outcome}}">
    <span class="tno-find-flaw-attempt-index">#{{attempt.index}}</span>
    <span class="tno-find-flaw-attempt-dice">
      {{#each attempt.dice as |die|}}
      <span class="tno-find-flaw-die{{#if die.isCounted}} counted{{/if}}">{{die.value}}</span>
      {{/each}}
    </span>
    <span class="tno-find-flaw-attempt-outcome">{{attempt.outcomeLabel}}</span>
  </div>
  {{/each}}

  {{#if active}}
  <a class="tno-find-flaw-reroll">
    <i class="fa-solid fa-arrow-rotate-right"></i> {{rerollLabel}}
  </a>
  {{else}}
  <div class="tno-find-flaw-done {{#if succeeded}}success{{else}}failure{{/if}}">{{doneLabel}}</div>
  {{/if}}
</div>
