<div class="joster-custom-skills-overview flexcol">
  <div class="overview-toolbar flexrow">
    <a class="overview-refresh" title="{{localize 'JOSTER.CustomSkillsOverview.Refresh'}}">
      <i class="fas fa-rotate"></i> {{localize "JOSTER.CustomSkillsOverview.Refresh"}}
    </a>
  </div>

  {{#if isEmpty}}
  <p class="overview-empty">{{localize "JOSTER.CustomSkillsOverview.Empty"}}</p>
  {{else}}
  <table class="overview-table">
    <thead>
      <tr>
        <th>{{localize "JOSTER.CustomSkillsOverview.Actor"}}</th>
        <th>{{localize "JOSTER.CustomSkillsOverview.Skill"}}</th>
        <th>{{localize "JOSTER.CustomSkillsOverview.Category"}}</th>
        <th>{{localize "JOSTER.CustomSkillsOverview.Attribute"}}</th>
        <th>{{localize "JOSTER.CustomSkillsOverview.Rank"}}</th>
        <th>{{localize "JOSTER.CustomSkillsOverview.Xp"}}</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each rows as |row|}}
      <tr>
        <td>{{row.actorName}}</td>
        <td>{{row.label}}</td>
        <td>{{row.category}}</td>
        <td>{{row.attribute}}</td>
        <td>{{row.rank}}</td>
        <td>{{row.xp}}</td>
        <td>
          <a class="overview-open-actor" data-actor-id="{{row.actorId}}" title="{{localize 'JOSTER.CustomSkillsOverview.OpenSheet'}}">
            <i class="fas fa-arrow-up-right-from-square"></i>
          </a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}
</div>
