<form class="joster-roll-dialog flexcol">
  <div class="joster-roll-subject">
    <h2 class="joster-roll-subject-name">{{subject}}</h2>
  </div>

  <div class="joster-roll-stats">
    {{#if isSkillMode}}
    <div class="joster-roll-detail joster-roll-attribute-row">
      <span class="joster-roll-detail-label joster-attribute-toggle" title="{{localize 'JOSTER.Roll.OverrideAttribute'}}">{{attributeLabel}}</span>
      <select name="attributeA" class="joster-attribute-select joster-hidden">
        {{#each abilities as |label key|}}
        <option value="{{key}}" {{#ifEquals key ../attributeA}}selected{{/ifEquals}}>{{label}}</option>
        {{/each}}
      </select>
      <span class="joster-roll-detail-value">{{attributeValue}}</span>
    </div>
    <div class="joster-roll-nonstandard-badge {{#unless isOverridden}}joster-hidden{{/unless}}">{{localize "JOSTER.Roll.NonStandard"}}</div>
    <div class="joster-roll-detail">
      <span class="joster-roll-detail-label">{{skillLabel}}</span>
      <span class="joster-roll-detail-value">{{skillValue}}</span>
    </div>
    {{else}}
    <div class="form-group">
      <label>{{localize "JOSTER.Roll.AttributeA"}}</label>
      <select name="attributeA">
        <option value="">-</option>
        {{#each abilities as |label key|}}
        <option value="{{key}}" {{#ifEquals key ../attributeA}}selected{{/ifEquals}}>{{label}}</option>
        {{/each}}
      </select>
    </div>

    <div class="form-group">
      <label>{{localize "JOSTER.Roll.AttributeB"}}</label>
      <select name="attributeB">
        <option value="">-</option>
        {{#each abilities as |label key|}}
        <option value="{{key}}" {{#ifEquals key ../attributeB}}selected{{/ifEquals}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
  </div>

  <hr class="joster-roll-divider"/>

  <div class="form-group">
    <label>{{localize "JOSTER.Roll.Bonus"}}</label>
    <div class="joster-bonus-stepper-group flexrow flex-center">
      <a class="joster-bonus-stepper" data-action="decrement">−</a>
      <span class="joster-bonus-value">{{bonus}}</span>
      <a class="joster-bonus-stepper" data-action="increment">+</a>
    </div>
    <input type="hidden" name="bonus" value="{{bonus}}"/>
  </div>

  <div class="form-group joster-advantage-field">
    <label>{{localize "JOSTER.Roll.Advantage"}}</label>
    <div class="joster-advantage-group flexrow flex-center">
      {{#each advantageOptions as |option|}}
      <a class="joster-advantage-option {{#ifEquals option.value ../advantage}}active{{/ifEquals}}" data-value="{{option.value}}" title="{{option.label}}">{{option.abbr}}</a>
      {{/each}}
    </div>
    <input type="hidden" name="advantage" value="{{advantage}}"/>
  </div>

  <hr class="joster-roll-divider"/>

  <div class="joster-roll-threshold-preview">
    {{localize "JOSTER.Roll.Threshold"}}: &lt;= <span class="joster-threshold-value">{{threshold}}</span>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fas fa-dice-d20"></i> {{localize "JOSTER.Roll.Submit"}}</button>
  </footer>
</form>
