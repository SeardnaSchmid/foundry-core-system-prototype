<form class="joster-roll-dialog flexcol">
  <div class="form-group">
    <label>{{localize "JOSTER.Roll.AttributeA"}}</label>
    <select name="attributeA">
      <option value="">-</option>
      {{#each abilities as |label key|}}
      <option value="{{key}}" {{#ifEquals key ../attributeA}}selected{{/ifEquals}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "JOSTER.Roll.AttributeB"}}</label>
    <select name="attributeB">
      <option value="">-</option>
      {{#each abilities as |label key|}}
      <option value="{{key}}" {{#ifEquals key ../attributeB}}selected{{/ifEquals}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "JOSTER.Roll.Bonus"}}</label>
    <input type="number" name="bonus" value="{{bonus}}" step="3"/>
  </div>

  <div class="form-group">
    <label>{{localize "JOSTER.Roll.Advantage"}}</label>
    <select name="advantage">
      {{#each advantageOptions as |option|}}
      <option value="{{option.value}}" {{#ifEquals option.value ../advantage}}selected{{/ifEquals}}>{{option.label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="joster-roll-threshold-preview">
    {{localize "JOSTER.Roll.Threshold"}}: <span class="joster-threshold-value">{{threshold}}</span>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit"><i class="fas fa-dice-d20"></i> {{localize "JOSTER.Roll.Submit"}}</button>
  </footer>
</form>
