<form class="tno-advance-dialog flexcol">

  {{!-- Progress toward the next rank: current rank -> next, XP over the cost
  of that step, and a bar. At max rank the bar is full and the cost line is
  replaced by a "maxed out" note. --}}
  <div class="advance-progress">
    <div class="advance-progress-head flexrow">
      {{#if atMax}}
      <span class="advance-rank">{{localize "TNO.AdvanceMaxRank"}}</span>
      {{else}}
      <span class="advance-rank">{{localize "TNO.SkillRankLabel"}} {{rank}} <i class="fas fa-arrow-right"></i> {{nextRank}}</span>
      <span class="advance-xp-count">{{xp}}/{{cost}} XP</span>
      {{/if}}
    </div>
    <div class="advance-bar">
      <div class="advance-bar-fill{{#if canBuy}} ready{{/if}}" style="width: {{percent}}%;"></div>
    </div>
  </div>

  {{!-- Guided actions apply immediately to the actor (no pending state), so
  spend/refund one XP or buy the next rank take effect on click. Buy only
  enables once enough XP is banked; buying consumes that rank's cost and any
  surplus carries over. Shift-click steps XP by 5. --}}
  <div class="advance-actions flexrow">
    <button type="button" class="advance-action" data-action="xp-dec" {{#unless canDecXp}}disabled{{/unless}} title="{{localize 'TNO.AdvanceXpDecHint'}}">−1 XP</button>
    <button type="button" class="advance-action" data-action="xp-inc" {{#if atMax}}disabled{{/if}} title="{{localize 'TNO.AdvanceXpIncHint'}}">+1 XP</button>
    <button type="button" class="advance-action advance-buy" data-action="buy" {{#unless canBuy}}disabled{{/unless}} title="{{localize 'TNO.AdvanceBuyHint'}}">
      <i class="fas fa-arrow-up"></i> {{localize "TNO.AdvanceBuy"}}{{#unless atMax}} ({{cost}} XP){{/unless}}
    </button>
  </div>

  {{#unless atMax}}
  <p class="advance-hint">
    {{#if canBuy}}{{localize "TNO.AdvanceReadyHint"}}{{else}}{{localize "TNO.AdvanceNeedHint" n=remaining}}{{/if}}
  </p>
  {{/unless}}

  {{!-- Manual correction: collapsed by default since it's the rare
  error-fixing path. Rank and XP are directly editable; the Save button here
  persists whatever is in these fields. --}}
  <details class="advance-correction">
    <summary>{{localize "TNO.AdvanceCorrection"}}</summary>
    <div class="flexrow">
      <div class="form-group">
        <label>{{localize "TNO.AdvanceCorrectionRankLabel"}}</label>
        <input type="number" name="rank" value="{{rank}}" min="{{rankMin}}" max="10"/>
      </div>
      <div class="form-group">
        <label>{{localize "TNO.AdvanceCorrectionXpLabel"}}</label>
        <input type="number" name="xp" value="{{xp}}" min="0"/>
      </div>
    </div>
    <footer class="sheet-footer flexrow">
      <button type="submit"><i class="fas fa-check"></i> {{localize "TNO.SkillAdvanceSubmit"}}</button>
    </footer>
  </details>
</form>
